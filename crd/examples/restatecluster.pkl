import "../RestateCluster.pkl"

cluster = (RestateCluster) {
  metadata {
    name = "restate-test"
  }
  spec {
    cluster {
      autoProvision = true
    }
    compute {
      image = "restatedev/restate:1.6.2"
    }
    storage {
      storageRequestBytes = 2.gib.toUnit("b").value as Int
    }
    config = """
      auto-provision = false
      """
  }
}

output {
  renderer = new YamlRenderer {
    isStream = true
  }
  value = new Listing {
    cluster
  }
}
